PORT=7200
DATABASE_URL=postgres://metacore:metacore@localhost:5432/metacore?sslmode=disable
JWT_SECRET=change-me-super-long-random-secret-at-least-32-chars
CORS_ORIGINS=http://localhost:5173
# Web Push (optional). Generate with:
#   docker run --rm node:22-alpine npx -y web-push generate-vapid-keys
# Leave both empty to disable push (kernel skips the /push routes).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Seed Demo Org + admin user + sample products/customers/notifications on
# boot so a fresh `docker compose up` is immediately usable. Set to false
# (or 0/no/off) to disable in production. Out of process you can run the
# same logic with: go run ./cmd/seed --seed
SEED_DEMO_DATA=true

# Override the default seeded identity. Picked up by every seeder via
# database/seeders/config.go — keeps the demo content out of code.
SEED_ADMIN_EMAIL=admin@demo.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Demo Admin
SEED_ORG_NAME=Demo Org
SEED_ORG_SLUG=demo-org
