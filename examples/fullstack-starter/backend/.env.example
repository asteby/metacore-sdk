PORT=7200
DATABASE_URL=postgres://metacore:metacore@localhost:5432/metacore?sslmode=disable
JWT_SECRET=change-me-super-long-random-secret-at-least-32-chars
CORS_ORIGINS=http://localhost:5173
# Web Push (optional). Generate with:
#   docker run --rm node:22-alpine npx -y web-push generate-vapid-keys
# Leave both empty to disable push (kernel skips the /push routes).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Seed admin@demo.com / admin123 + Demo Org + sample products/customers on
# boot so a fresh `docker compose up` is immediately usable. Set to false
# (or 0/no/off) to disable in production.
SEED_DEMO_DATA=true
