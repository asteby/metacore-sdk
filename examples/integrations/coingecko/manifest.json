{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "coingecko",
    "name": "Precios Crypto (CoinGecko)",
    "version": "1.0.0",
    "description": "Consulta precios actuales de cualquier criptomoneda en USD, MXN u otras divisas. Sin API key requerida.",
    "category": "research",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=coingecko.com&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.coingecko.com",
      "reason": "Consulta de precios crypto"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "crypto_price",
        "description": "Obtiene el precio actual de una o varias criptomonedas. Usa el ID de CoinGecko: bitcoin, ethereum, solana, dogecoin, etc.",
        "input_schema": {
          "type": "object",
          "properties": {
            "coin_ids": {
              "type": "string",
              "description": "ID(s) de la crypto en CoinGecko separados por coma"
            }
          },
          "required": [
            "coin_ids"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.coingecko.com/api/v3/simple/price?ids={{coin_ids}}&vs_currencies=usd,mxn"
        }
      }
    ]
  }
}
