{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "deepgram_tts",
    "name": "Deepgram — Texto a Voz",
    "version": "1.0.0",
    "description": "Convierte texto en audio con voces naturales de Deepgram Aura. Ideal para enviar notas de voz al usuario.",
    "category": "communication",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=deepgram.com&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.deepgram.com",
      "reason": "Síntesis de voz vía Deepgram Aura"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "text_to_speech",
        "description": "Convierte un texto corto en un mensaje de voz (audio) y lo envía al usuario. Útil para dar un toque humano o cuando el usuario solicita un audio/nota de voz.",
        "input_schema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "Texto a convertir en audio (mensaje de voz). Sé breve y natural."
            },
            "deepgram_model": {
              "type": "string",
              "description": "Modelo de voz Deepgram Aura. Normalmente se toma del setting."
            }
          },
          "required": [
            "text"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.deepgram.com/v1/speak?model={{deepgram_model}}"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "deepgram_api_key",
      "type": "secret",
      "label": "Deepgram API Key"
    },
    {
      "key": "deepgram_model",
      "type": "string",
      "label": "Modelo de voz",
      "default": "aura-asteria-en"
    }
  ]
}
