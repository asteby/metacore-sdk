{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "dhl_tracking",
    "name": "DHL Tracking",
    "version": "1.0.0",
    "description": "Rastrea envíos de DHL Express en tiempo real.",
    "category": "logistics",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=dhl.com&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api-eu.dhl.com",
      "reason": "Tracking DHL — región Europa"
    },
    {
      "kind": "http:fetch",
      "target": "api-us.dhl.com",
      "reason": "Tracking DHL — región Américas"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "track_shipment",
        "description": "Rastrea un envío de DHL con el número de guía.",
        "input_schema": {
          "type": "object",
          "properties": {
            "tracking_number": {
              "type": "string",
              "description": "Número de guía o tracking de DHL"
            }
          },
          "required": [
            "tracking_number"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api-eu.dhl.com/track/shipments?trackingNumber={{tracking_number}}"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "dhl_api_key",
      "type": "secret",
      "label": "DHL API Key"
    },
    {
      "key": "dhl_region",
      "type": "select",
      "label": "Región API",
      "default": "eu",
      "options": [
        {
          "value": "eu",
          "label": "Europa (api-eu.dhl.com)"
        },
        {
          "value": "us",
          "label": "Américas (api-us.dhl.com)"
        }
      ]
    }
  ]
}
