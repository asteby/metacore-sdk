{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "elevenlabs_tts",
    "name": "ElevenLabs — Texto a Voz",
    "version": "1.0.0",
    "description": "Voces ultra-realistas con IA de ElevenLabs. Soporta clonación de voz y múltiples idiomas.",
    "category": "communication",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=elevenlabs.io&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.elevenlabs.io",
      "reason": "Síntesis de voz vía ElevenLabs"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "text_to_speech",
        "description": "Convierte un texto corto en un mensaje de voz con la voz configurada de ElevenLabs. Útil para notas de voz personalizadas.",
        "input_schema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "Texto a convertir en audio (mensaje de voz). Sé breve y natural."
            },
            "elevenlabs_voice_id": {
              "type": "string",
              "description": "ID de la voz de ElevenLabs a usar. Normalmente se toma del setting con el mismo nombre."
            }
          },
          "required": [
            "text"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.elevenlabs.io/v1/text-to-speech/{{elevenlabs_voice_id}}"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "elevenlabs_api_key",
      "type": "secret",
      "label": "ElevenLabs API Key"
    },
    {
      "key": "elevenlabs_voice_id",
      "type": "string",
      "label": "Voice ID por defecto"
    },
    {
      "key": "elevenlabs_model",
      "type": "string",
      "label": "Modelo"
    }
  ]
}
