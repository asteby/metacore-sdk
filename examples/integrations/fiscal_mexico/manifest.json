{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "fiscal_mexico",
    "name": "Facturación Electrónica México (CFDI 4.0)",
    "version": "1.0.0",
    "description": "Emisión y cancelación de CFDI ante el SAT vía PAC (factura.com). Catálogos SAT, extensiones fiscales para facturas/clientes/productos y herramientas LLM para agentes conversacionales.",
    "category": "integration",
    "icon": {
      "type": "lucide",
      "slug": "FileText",
      "color": "#F59E0B"
    },
    "author": "Asteby",
    "website": "https://asteby.com",
    "license": "MIT",
    "features": [
      "Timbrado CFDI 4.0 vía factura.com",
      "Cancelación de documentos fiscales",
      "Catálogos SAT completos (uso CFDI, formas de pago, régimen fiscal)",
      "Modals compilados para timbrar y cancelar",
      "Herramientas LLM para agentes conversacionales"
    ]
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "schema",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "*.factura.com",
      "reason": "PAC para timbrado/cancelación CFDI"
    },
    {
      "kind": "http:fetch",
      "target": "*.sat.gob.mx",
      "reason": "Validación ante SAT"
    },
    {
      "kind": "event:emit",
      "target": "fiscal.*",
      "reason": "Notificar eventos de timbrado"
    }
  ],
  "models": [
    {
      "key": "FiscalDocuments",
      "table": "fiscal_documents",
      "label": "Documentos Fiscales",
      "columns": [
        {
          "name": "id",
          "type": "uuid",
          "primary_key": true,
          "default": "gen_random_uuid()"
        },
        {
          "name": "organization_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "invoice_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "fiscal_uuid",
          "type": "text"
        },
        {
          "name": "rfc_emisor",
          "type": "text",
          "not_null": true
        },
        {
          "name": "rfc_receptor",
          "type": "text",
          "not_null": true
        },
        {
          "name": "total",
          "type": "numeric",
          "not_null": true
        },
        {
          "name": "status",
          "type": "text",
          "not_null": true,
          "default": "draft"
        },
        {
          "name": "cfdi_usage",
          "type": "text"
        },
        {
          "name": "payment_form",
          "type": "text"
        },
        {
          "name": "payment_method",
          "type": "text"
        },
        {
          "name": "environment",
          "type": "text",
          "default": "sandbox"
        },
        {
          "name": "xml_url",
          "type": "text"
        },
        {
          "name": "pdf_url",
          "type": "text"
        },
        {
          "name": "xml",
          "type": "text"
        },
        {
          "name": "stamped_at",
          "type": "timestamptz"
        },
        {
          "name": "cancelled_at",
          "type": "timestamptz"
        },
        {
          "name": "cancel_reason",
          "type": "text"
        },
        {
          "name": "replacement_uuid",
          "type": "text"
        },
        {
          "name": "provider_data",
          "type": "jsonb"
        }
      ]
    }
  ],
  "frontend": {
    "entry": "/api/metacore/addons/fiscal_mexico/frontend/remoteEntry.js",
    "format": "federation",
    "expose": "./plugin",
    "container": "metacore_fiscal_mexico"
  },
  "contributions": {
    "navigation": [
      {
        "title": "addons.fiscal_mexico.sidebar.fiscal",
        "icon": "FileText",
        "target": "sidebar.finance",
        "items": [
          {
            "title": "addons.fiscal_mexico.sidebar.fiscal_documents",
            "model": "FiscalDocuments",
            "icon": "FileCheck"
          }
        ]
      }
    ],
    "actions": [
      {
        "key": "stamp_fiscal",
        "label": "addons.fiscal_mexico.actions.stamp",
        "icon": "FileCheck",
        "handler": {
          "type": "wasm",
          "function": "StampFiscal"
        },
        "target_model": "FiscalDocuments",
        "modal": "fiscal_mexico.stamp_fiscal",
        "fields": [
          {
            "key": "cfdi_usage",
            "type": "select",
            "label": "Uso CFDI",
            "required": true,
            "options": [
              {
                "value": "G01",
                "label": "G01 — Adquisición de mercancías"
              },
              {
                "value": "G03",
                "label": "G03 — Gastos en general"
              },
              {
                "value": "I01",
                "label": "I01 — Construcciones"
              },
              {
                "value": "P01",
                "label": "P01 — Por definir"
              },
              {
                "value": "S01",
                "label": "S01 — Sin efectos fiscales"
              }
            ]
          },
          {
            "key": "payment_form",
            "type": "select",
            "label": "Forma de pago",
            "required": true,
            "options": [
              {
                "value": "01",
                "label": "01 — Efectivo"
              },
              {
                "value": "03",
                "label": "03 — Transferencia electrónica"
              },
              {
                "value": "04",
                "label": "04 — Tarjeta de crédito"
              },
              {
                "value": "28",
                "label": "28 — Tarjeta de débito"
              },
              {
                "value": "99",
                "label": "99 — Por definir"
              }
            ]
          },
          {
            "key": "payment_method",
            "type": "select",
            "label": "Método de pago",
            "required": true,
            "options": [
              {
                "value": "PUE",
                "label": "PUE — Pago en una exhibición"
              },
              {
                "value": "PPD",
                "label": "PPD — Pago diferido"
              }
            ]
          },
          {
            "key": "test_mode",
            "type": "boolean",
            "label": "Modo sandbox"
          }
        ]
      },
      {
        "key": "cancel_fiscal",
        "label": "addons.fiscal_mexico.actions.cancel",
        "icon": "FileX",
        "handler": {
          "type": "wasm",
          "function": "CancelFiscal"
        },
        "target_model": "FiscalDocuments",
        "modal": "fiscal_mexico.cancel_fiscal",
        "fields": [
          {
            "key": "cancel_reason",
            "type": "select",
            "label": "Motivo",
            "required": true,
            "options": [
              {
                "value": "01",
                "label": "01 — Emitido con errores, con relación"
              },
              {
                "value": "02",
                "label": "02 — Emitido con errores, sin relación"
              },
              {
                "value": "03",
                "label": "03 — No se llevó a cabo la operación"
              },
              {
                "value": "04",
                "label": "04 — Operación nominativa en factura global"
              }
            ]
          },
          {
            "key": "replacement_uuid",
            "type": "text",
            "label": "UUID sustituto (motivo 01)"
          }
        ]
      }
    ],
    "tools": [
      {
        "key": "stamp_fiscal",
        "description": "Emite y timbra un CFDI ante el SAT a partir de una venta. Úsalo cuando el usuario pida 'timbra la factura X'. NO usar para borradores sin RFC receptor.",
        "input_schema": {
          "type": "object",
          "properties": {
            "invoice_id": {
              "type": "string",
              "description": "UUID de la factura draft a timbrar"
            },
            "cfdi_usage": {
              "type": "string"
            },
            "payment_form": {
              "type": "string"
            },
            "payment_method": {
              "type": "string"
            }
          },
          "required": [
            "invoice_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/stamp_fiscal"
        }
      },
      {
        "key": "cancel_fiscal",
        "description": "Cancela un CFDI timbrado usando su UUID fiscal. Pide motivo (01, 02, 03, 04).",
        "input_schema": {
          "type": "object",
          "properties": {
            "fiscal_uuid": {
              "type": "string",
              "description": "UUID fiscal del CFDI a cancelar"
            },
            "cancel_reason": {
              "type": "string"
            },
            "replacement_uuid": {
              "type": "string"
            }
          },
          "required": [
            "fiscal_uuid",
            "cancel_reason"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/cancel_fiscal"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "api_key",
      "type": "secret",
      "label": "API Key de factura.com"
    },
    {
      "key": "api_secret",
      "type": "secret",
      "label": "API Secret de factura.com"
    },
    {
      "key": "environment",
      "type": "select",
      "label": "Ambiente",
      "default": "sandbox",
      "options": [
        {
          "value": "sandbox",
          "label": "Sandbox (pruebas)"
        },
        {
          "value": "live",
          "label": "Producción"
        }
      ]
    },
    {
      "key": "series",
      "type": "string",
      "label": "Serie de factura",
      "default": "A"
    },
    {
      "key": "auto_stamp",
      "type": "boolean",
      "label": "Timbrar automáticamente al emitir",
      "default": false
    }
  ]
}
