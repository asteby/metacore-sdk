{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "github",
    "name": "GitHub",
    "version": "1.0.0",
    "description": "Gestiona issues y comentarios en repositorios de GitHub desde conversaciones.",
    "category": "dev",
    "icon": {
      "type": "brand",
      "slug": "github",
      "color": "#181717"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.github.com",
      "reason": "Crear y modificar issues/comentarios en GitHub"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "create_issue",
        "description": "Abre un nuevo issue en el repositorio.",
        "input_schema": {
          "type": "object",
          "properties": {
            "github_repo": {
              "type": "string",
              "description": "Repositorio destino (owner/repo). Por default usa el configurado en settings."
            },
            "title": {
              "type": "string",
              "description": "Título del issue"
            },
            "body": {
              "type": "string",
              "description": "Descripción detallada"
            },
            "labels": {
              "type": "string",
              "description": "Etiquetas separadas por coma"
            }
          },
          "required": [
            "github_repo",
            "title",
            "body"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.github.com/repos/{{github_repo}}/issues"
        }
      },
      {
        "key": "add_comment",
        "description": "Agrega un comentario a un issue existente.",
        "input_schema": {
          "type": "object",
          "properties": {
            "github_repo": {
              "type": "string",
              "description": "Repositorio destino (owner/repo)."
            },
            "issue_number": {
              "type": "number",
              "description": "Número del issue"
            },
            "comment": {
              "type": "string",
              "description": "Texto del comentario"
            }
          },
          "required": [
            "github_repo",
            "issue_number",
            "comment"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.github.com/repos/{{github_repo}}/issues/{{issue_number}}/comments"
        }
      },
      {
        "key": "close_issue",
        "description": "Cierra un issue existente.",
        "input_schema": {
          "type": "object",
          "properties": {
            "github_repo": {
              "type": "string",
              "description": "Repositorio destino (owner/repo)."
            },
            "issue_number": {
              "type": "number",
              "description": "Número del issue a cerrar"
            }
          },
          "required": [
            "github_repo",
            "issue_number"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.github.com/repos/{{github_repo}}/issues/{{issue_number}}"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "github_token",
      "type": "secret",
      "label": "Personal Access Token"
    },
    {
      "key": "github_repo",
      "type": "string",
      "label": "Repositorio (owner/repo)"
    }
  ]
}
