{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "google_sheets",
    "name": "Google Sheets",
    "version": "1.0.0",
    "description": "Registra datos en hojas de cálculo de Google Sheets desde conversaciones.",
    "category": "productivity",
    "icon": {
      "type": "brand",
      "slug": "googlesheets",
      "color": "#34A853"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "*.googleapis.com",
      "reason": "Escribir filas en Google Sheets API"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "append_row",
        "description": "Agrega una fila con datos al final de la hoja de cálculo.",
        "input_schema": {
          "type": "object",
          "properties": {
            "gsheets_spreadsheet_id": {
              "type": "string",
              "description": "ID del spreadsheet (default = settings)"
            },
            "gsheets_sheet_name": {
              "type": "string",
              "description": "Pestaña destino (default = settings)"
            },
            "col1": {
              "type": "string",
              "description": "Valor para columna A"
            },
            "col2": {
              "type": "string",
              "description": "Valor para columna B"
            },
            "col3": {
              "type": "string",
              "description": "Valor para columna C"
            },
            "col4": {
              "type": "string",
              "description": "Valor para columna D"
            }
          },
          "required": [
            "gsheets_spreadsheet_id",
            "gsheets_sheet_name",
            "col1"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://sheets.googleapis.com/v4/spreadsheets/{{gsheets_spreadsheet_id}}/values/{{gsheets_sheet_name}}!A1:append?valueInputOption=USER_ENTERED"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "gsheets_token",
      "type": "secret",
      "label": "OAuth Access Token"
    },
    {
      "key": "gsheets_spreadsheet_id",
      "type": "string",
      "label": "ID de la hoja"
    },
    {
      "key": "gsheets_sheet_name",
      "type": "string",
      "label": "Nombre de la pestaña"
    }
  ]
}
