{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "jina_reader",
    "name": "Lector de Páginas Web (Jina)",
    "version": "1.0.0",
    "description": "Extrae el contenido legible de cualquier URL: artículos, documentación, páginas de producto. Sin API key requerida.",
    "category": "research",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=jina.ai&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "r.jina.ai",
      "reason": "Extracción de contenido de URLs vía Jina Reader"
    },
    {
      "kind": "http:fetch",
      "target": "s.jina.ai",
      "reason": "Búsqueda web vía Jina Search"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "read_url",
        "description": "Obtiene el contenido en texto plano de una página web. Útil para resumir artículos, documentación o páginas de producto.",
        "input_schema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "URL completa de la página a leer"
            }
          },
          "required": [
            "url"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://r.jina.ai/{{url}}"
        }
      },
      {
        "key": "search_web",
        "description": "Realiza una búsqueda web vía Jina Search y devuelve los resultados como texto plano listo para LLM.",
        "input_schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Consulta de búsqueda"
            }
          },
          "required": [
            "query"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://s.jina.ai/{{query}}"
        }
      }
    ]
  }
}
