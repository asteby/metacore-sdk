{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "jira",
    "name": "Jira",
    "version": "1.0.0",
    "description": "Crea issues en Jira para equipos enterprise.",
    "category": "dev",
    "icon": {
      "type": "brand",
      "slug": "jira",
      "color": "#0052CC"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "*.atlassian.net",
      "reason": "Crear issues en Jira Cloud"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "create_issue",
        "description": "Crea un nuevo issue/tarea en Jira.",
        "input_schema": {
          "type": "object",
          "properties": {
            "jira_domain": {
              "type": "string",
              "description": "Subdominio Atlassian (sin .atlassian.net). Por default usa settings."
            },
            "title": {
              "type": "string",
              "description": "Título del issue"
            },
            "description": {
              "type": "string",
              "description": "Descripción detallada"
            }
          },
          "required": [
            "jira_domain",
            "title",
            "description"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://{{jira_domain}}.atlassian.net/rest/api/3/issue"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "jira_domain",
      "type": "string",
      "label": "Dominio (subdomain de atlassian.net)"
    },
    {
      "key": "jira_basic_auth",
      "type": "secret",
      "label": "Auth Token (Base64)"
    },
    {
      "key": "jira_project_key",
      "type": "string",
      "label": "Clave del Proyecto"
    }
  ]
}
