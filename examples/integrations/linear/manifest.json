{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "linear",
    "name": "Linear",
    "version": "1.0.0",
    "description": "Crea y consulta issues en Linear para gestionar proyectos de desarrollo.",
    "category": "dev",
    "icon": {
      "type": "brand",
      "slug": "linear",
      "color": "#5E6AD2"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.linear.app",
      "reason": "Ejecutar mutations GraphQL en Linear"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "create_issue",
        "description": "Crea un nuevo issue en Linear.",
        "input_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Título del issue"
            },
            "description": {
              "type": "string",
              "description": "Descripción detallada"
            }
          },
          "required": [
            "title",
            "description"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.linear.app/graphql"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "linear_api_key",
      "type": "secret",
      "label": "API Key"
    },
    {
      "key": "linear_team_id",
      "type": "string",
      "label": "Team ID"
    }
  ]
}
