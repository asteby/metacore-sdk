{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "mercadopago",
    "name": "MercadoPago",
    "version": "1.0.0",
    "description": "Consulta cobros y genera links de pago con MercadoPago. Ideal para LATAM.",
    "category": "payments",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=mercadopago.com&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "*.mercadopago.com",
      "reason": "Llamadas a la API de MercadoPago"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "get_payment",
        "description": "Consulta el estado de un pago en MercadoPago.",
        "input_schema": {
          "type": "object",
          "properties": {
            "payment_id": {
              "type": "string",
              "description": "ID del pago"
            }
          },
          "required": [
            "payment_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.mercadopago.com/v1/payments/{{payment_id}}"
        }
      },
      {
        "key": "create_payment_link",
        "description": "Genera un link de checkout para cobrar un monto.",
        "input_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Concepto del cobro"
            },
            "amount": {
              "type": "number",
              "description": "Monto en pesos (ej: 500.00)"
            }
          },
          "required": [
            "title",
            "amount"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.mercadopago.com/checkout/preferences"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "mercadopago_access_token",
      "type": "secret",
      "label": "Access Token"
    }
  ]
}
