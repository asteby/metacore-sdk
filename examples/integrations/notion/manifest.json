{
  "key": "notion",
  "name": "Notion",
  "description": "Agrega registros a bases de datos de Notion desde conversaciones.",
  "version": "1.0.0",
  "category": "productivity",
  "icon": "notion",
  "icon_type": "brand",
  "icon_slug": "notion",
  "icon_color": "000000",
  "kernel": ">=2.0.0 <3.0.0",
  "tenant_isolation": "shared",
  "settings": [
    {
      "key": "notion_api_key",
      "label": "Integration Token",
      "type": "password",
      "secret": true
    },
    {
      "key": "notion_database_id",
      "label": "Database ID",
      "type": "string"
    }
  ],
  "tools": [
    {
      "id": "create_entry",
      "name": "Crear Registro",
      "description": "Agrega una nueva entrada a la base de datos de Notion.",
      "input_schema": [
        {
          "name": "title",
          "type": "string",
          "description": "Título de la entrada",
          "required": true,
          "extraction_hint": "Nombre o asunto principal"
        },
        {
          "name": "notes",
          "type": "string",
          "description": "Notas o detalles adicionales",
          "extraction_hint": "Contexto adicional de la conversación"
        }
      ],
      "endpoint": "https://api.notion.com/v1/pages",
      "method": "POST"
    }
  ],
  "events": [],
  "backend": {
    "runtime": "webhook"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "*.notion.com",
      "reason": "Crear y leer páginas en la API de Notion"
    }
  ],
  "author": "asteby",
  "license": "MIT"
}
