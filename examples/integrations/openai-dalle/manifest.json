{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "openai_dalle",
    "name": "OpenAI DALL·E",
    "version": "1.0.0",
    "description": "Genera imágenes con IA usando DALL·E 3 de OpenAI.",
    "category": "ai",
    "icon": {
      "type": "brand",
      "slug": "openai",
      "color": "#412991"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.openai.com",
      "reason": "Generación de imágenes vía DALL·E"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "generate_image",
        "description": "Genera una imagen a partir de una descripción de texto usando DALL·E 3.",
        "input_schema": {
          "type": "object",
          "properties": {
            "prompt": {
              "type": "string",
              "description": "Descripción de la imagen a generar"
            }
          },
          "required": [
            "prompt"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.openai.com/v1/images/generations"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "openai_api_key",
      "type": "secret",
      "label": "OpenAI API Key"
    }
  ]
}
