{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "orders",
    "name": "Pedidos",
    "version": "1.0.0",
    "description": "Registra y gestiona pedidos de venta directamente en Link. Incluye modals para cumplir y cancelar pedidos, y tools LLM para crear/consultar.",
    "category": "productivity",
    "icon": {
      "type": "lucide",
      "slug": "ShoppingCart",
      "color": "#10B981"
    },
    "author": "Asteby",
    "website": "https://asteby.com",
    "license": "MIT",
    "features": [
      "Gestión de pedidos (crear, consultar, cumplir, cancelar)",
      "Modals compilados para fulfillment y cancelación",
      "Herramientas LLM para agentes conversacionales"
    ]
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "schema",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "event:emit",
      "target": "orders.*",
      "reason": "Notificar eventos de pedidos"
    }
  ],
  "models": [
    {
      "key": "Orders",
      "table": "orders",
      "label": "Pedidos",
      "columns": [
        {
          "name": "id",
          "type": "uuid",
          "primary_key": true,
          "default": "gen_random_uuid()"
        },
        {
          "name": "organization_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "customer_id",
          "type": "uuid"
        },
        {
          "name": "status",
          "type": "text",
          "not_null": true,
          "default": "pending"
        },
        {
          "name": "payment_status",
          "type": "text",
          "default": "pending"
        },
        {
          "name": "total",
          "type": "numeric",
          "not_null": true,
          "default": 0
        },
        {
          "name": "shipping_cost",
          "type": "numeric",
          "default": 0
        },
        {
          "name": "currency",
          "type": "text",
          "default": "MXN"
        },
        {
          "name": "delivery_type",
          "type": "text",
          "default": "pickup"
        },
        {
          "name": "shipping_address",
          "type": "text"
        },
        {
          "name": "tracking_number",
          "type": "text"
        },
        {
          "name": "carrier",
          "type": "text"
        },
        {
          "name": "fulfilled_at",
          "type": "timestamptz"
        },
        {
          "name": "cancelled_at",
          "type": "timestamptz"
        },
        {
          "name": "cancel_reason",
          "type": "text"
        },
        {
          "name": "items",
          "type": "jsonb"
        },
        {
          "name": "notes",
          "type": "text"
        }
      ]
    }
  ],
  "frontend": {
    "entry": "/api/metacore/addons/orders/frontend/remoteEntry.js",
    "format": "federation",
    "expose": "./plugin",
    "container": "metacore_orders"
  },
  "contributions": {
    "navigation": [
      {
        "title": "addons.orders.sidebar.orders",
        "icon": "ShoppingCart",
        "target": "sidebar.operations",
        "items": [
          {
            "title": "addons.orders.sidebar.orders",
            "model": "Orders",
            "icon": "ShoppingCart"
          }
        ]
      }
    ],
    "actions": [
      {
        "key": "fulfill",
        "label": "addons.orders.actions.fulfill",
        "icon": "Truck",
        "handler": {
          "type": "wasm",
          "function": "Fulfill"
        },
        "target_model": "Orders",
        "modal": "orders.fulfill",
        "fields": [
          {
            "key": "tracking_number",
            "type": "text",
            "label": "Número de seguimiento",
            "required": true
          },
          {
            "key": "carrier",
            "type": "select",
            "label": "Empresa de envío",
            "required": true,
            "options": [
              {
                "value": "DHL",
                "label": "DHL"
              },
              {
                "value": "FedEx",
                "label": "FedEx"
              },
              {
                "value": "UPS",
                "label": "UPS"
              },
              {
                "value": "Estafeta",
                "label": "Estafeta"
              },
              {
                "value": "other",
                "label": "Otro"
              }
            ]
          },
          {
            "key": "notes",
            "type": "text",
            "label": "Notas"
          }
        ]
      },
      {
        "key": "cancel",
        "label": "addons.orders.actions.cancel",
        "icon": "X",
        "handler": {
          "type": "wasm",
          "function": "Cancel"
        },
        "target_model": "Orders",
        "modal": "orders.cancel",
        "fields": [
          {
            "key": "reason",
            "type": "text",
            "label": "Motivo",
            "required": true
          }
        ]
      }
    ],
    "tools": [
      {
        "key": "create_order",
        "description": "Crea un pedido de venta a partir de la conversación con el cliente.",
        "input_schema": {
          "type": "object",
          "properties": {
            "customer_id": {
              "type": "string",
              "description": "UUID del cliente"
            },
            "items": {
              "type": "string",
              "description": "JSON con items [{product_id,quantity,unit_price}]"
            },
            "total": {
              "type": "number"
            },
            "delivery_type": {
              "type": "string"
            },
            "shipping_address": {
              "type": "string"
            }
          },
          "required": [
            "customer_id",
            "items",
            "total"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/create_order"
        }
      },
      {
        "key": "get_order",
        "description": "Obtiene los detalles de un pedido por id.",
        "input_schema": {
          "type": "object",
          "properties": {
            "order_id": {
              "type": "string",
              "description": "UUID del pedido"
            }
          },
          "required": [
            "order_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/get_order"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "default_currency",
      "type": "string",
      "label": "Moneda por defecto",
      "default": "MXN"
    }
  ]
}
