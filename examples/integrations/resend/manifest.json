{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "resend",
    "name": "Resend",
    "version": "1.0.0",
    "description": "Envía correos electrónicos transaccionales con Resend. 100 emails/día gratis.",
    "category": "email",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=resend.com&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.resend.com",
      "reason": "API de envío de correos de Resend"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "send_email",
        "description": "Envía un correo electrónico a un destinatario.",
        "input_schema": {
          "type": "object",
          "properties": {
            "to_email": {
              "type": "string",
              "description": "Correo del destinatario"
            },
            "subject": {
              "type": "string",
              "description": "Asunto del correo"
            },
            "html_body": {
              "type": "string",
              "description": "Contenido del email en HTML"
            }
          },
          "required": [
            "to_email",
            "subject",
            "html_body"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.resend.com/emails"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "resend_api_key",
      "type": "secret",
      "label": "API Key"
    },
    {
      "key": "resend_from_email",
      "type": "string",
      "label": "Email remitente"
    }
  ]
}
