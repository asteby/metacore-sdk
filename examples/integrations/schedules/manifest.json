{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "schedules",
    "name": "Agenda",
    "version": "1.0.0",
    "description": "Agenda citas y eventos directamente en Link. Modals para confirmar, reagendar y cancelar; tools LLM para crear/listar.",
    "category": "productivity",
    "icon": {
      "type": "lucide",
      "slug": "CalendarCheck",
      "color": "#3B82F6"
    },
    "author": "Asteby",
    "website": "https://asteby.com",
    "license": "MIT",
    "features": [
      "Agenda de citas y eventos",
      "Modals para confirmar, reagendar y cancelar",
      "Herramientas LLM para agentes conversacionales"
    ]
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "schema",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "event:emit",
      "target": "schedules.*",
      "reason": "Notificar eventos de agenda"
    }
  ],
  "models": [
    {
      "key": "ScheduleEvents",
      "table": "schedule_events",
      "label": "Eventos de Agenda",
      "columns": [
        {
          "name": "id",
          "type": "uuid",
          "primary_key": true,
          "default": "gen_random_uuid()"
        },
        {
          "name": "organization_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "contact_id",
          "type": "uuid"
        },
        {
          "name": "title",
          "type": "text",
          "not_null": true
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "starts_at",
          "type": "timestamptz",
          "not_null": true
        },
        {
          "name": "ends_at",
          "type": "timestamptz",
          "not_null": true
        },
        {
          "name": "location",
          "type": "text"
        },
        {
          "name": "category",
          "type": "text",
          "default": "appointment"
        },
        {
          "name": "status",
          "type": "text",
          "not_null": true,
          "default": "scheduled"
        },
        {
          "name": "confirmed_at",
          "type": "timestamptz"
        },
        {
          "name": "cancelled_at",
          "type": "timestamptz"
        },
        {
          "name": "cancel_reason",
          "type": "text"
        }
      ]
    }
  ],
  "frontend": {
    "entry": "/api/metacore/addons/schedules/frontend/remoteEntry.js",
    "format": "federation",
    "expose": "./plugin",
    "container": "metacore_schedules"
  },
  "contributions": {
    "navigation": [
      {
        "title": "addons.schedules.sidebar.schedules",
        "icon": "CalendarCheck",
        "target": "sidebar.operations",
        "items": [
          {
            "title": "addons.schedules.sidebar.schedules",
            "model": "ScheduleEvents",
            "icon": "CalendarDays"
          }
        ]
      }
    ],
    "actions": [
      {
        "key": "confirm",
        "label": "addons.schedules.actions.confirm",
        "icon": "CheckCircle",
        "handler": {
          "type": "wasm",
          "function": "Confirm"
        },
        "target_model": "ScheduleEvents",
        "modal": "schedules.confirm"
      },
      {
        "key": "reschedule",
        "label": "addons.schedules.actions.reschedule",
        "icon": "CalendarClock",
        "handler": {
          "type": "wasm",
          "function": "Reschedule"
        },
        "target_model": "ScheduleEvents",
        "modal": "schedules.reschedule",
        "fields": [
          {
            "key": "starts_at",
            "type": "text",
            "label": "Nuevo inicio",
            "required": true
          },
          {
            "key": "ends_at",
            "type": "text",
            "label": "Nuevo fin",
            "required": true
          }
        ]
      },
      {
        "key": "cancel",
        "label": "addons.schedules.actions.cancel",
        "icon": "X",
        "handler": {
          "type": "wasm",
          "function": "Cancel"
        },
        "target_model": "ScheduleEvents",
        "modal": "schedules.cancel",
        "fields": [
          {
            "key": "reason",
            "type": "text",
            "label": "Motivo",
            "required": true
          }
        ]
      }
    ],
    "tools": [
      {
        "key": "create_event",
        "description": "Crea una cita o evento en la agenda.",
        "input_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "starts_at": {
              "type": "string",
              "description": "ISO 8601"
            },
            "ends_at": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "contact_id": {
              "type": "string"
            }
          },
          "required": [
            "title",
            "starts_at"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/create_event"
        }
      },
      {
        "key": "list_events",
        "description": "Consulta eventos de agenda filtrando por fecha, contacto o estado.",
        "input_schema": {
          "type": "object",
          "properties": {
            "contact_id": {
              "type": "string"
            },
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "status": {
              "type": "string"
            }
          }
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/list_events"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "default_duration_minutes",
      "type": "string",
      "label": "Duración por defecto (min)",
      "default": "60"
    }
  ]
}
