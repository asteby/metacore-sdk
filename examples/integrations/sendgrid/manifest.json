{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "sendgrid",
    "name": "SendGrid",
    "version": "1.0.0",
    "description": "Envía correos transaccionales con SendGrid de Twilio.",
    "category": "email",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=sendgrid.com&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.sendgrid.com",
      "reason": "API de envío de correos de SendGrid"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "send_email",
        "description": "Envía un correo electrónico vía SendGrid.",
        "input_schema": {
          "type": "object",
          "properties": {
            "to_email": {
              "type": "string",
              "description": "Correo del destinatario"
            },
            "subject": {
              "type": "string",
              "description": "Asunto del correo"
            },
            "html_body": {
              "type": "string",
              "description": "Contenido del email en HTML"
            }
          },
          "required": [
            "to_email",
            "subject",
            "html_body"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.sendgrid.com/v3/mail/send"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "sendgrid_api_key",
      "type": "secret",
      "label": "API Key"
    },
    {
      "key": "sendgrid_from_email",
      "type": "string",
      "label": "Email remitente"
    }
  ]
}
