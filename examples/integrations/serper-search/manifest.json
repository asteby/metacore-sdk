{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "serper_search",
    "name": "Búsqueda Google (Serper)",
    "version": "1.0.0",
    "description": "Busca en Google y obtiene resultados actualizados: noticias, precios, eventos. Plan gratuito: 2500 búsquedas/mes.",
    "category": "research",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=serper.dev&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "google.serper.dev",
      "reason": "Llamar a la API de Serper (Google Search)"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "google_search",
        "description": "Busca en Google y devuelve los resultados más relevantes. Úsalo para noticias, precios actuales, eventos recientes o cualquier información que requiera datos de internet.",
        "input_schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Consulta de búsqueda"
            }
          },
          "required": [
            "query"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://google.serper.dev/search"
        }
      },
      {
        "key": "google_news",
        "description": "Busca noticias recientes en Google News sobre un tema.",
        "input_schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Tema sobre el que buscar noticias"
            }
          },
          "required": [
            "query"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://google.serper.dev/news"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "serper_api_key",
      "type": "secret",
      "label": "Serper API Key"
    }
  ]
}
