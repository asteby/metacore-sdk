{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "shopify",
    "name": "Shopify",
    "version": "1.0.0",
    "description": "Consulta pedidos y productos de tu tienda Shopify.",
    "category": "crm",
    "icon": {
      "type": "brand",
      "slug": "shopify",
      "color": "#7AB55C"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "*.myshopify.com",
      "reason": "Admin API de la tienda del cliente"
    },
    {
      "kind": "http:fetch",
      "target": "*.shopify.com",
      "reason": "Endpoints auxiliares de Shopify"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "search_orders",
        "description": "Busca pedidos por número de orden en Shopify.",
        "input_schema": {
          "type": "object",
          "properties": {
            "order_number": {
              "type": "string",
              "description": "Número del pedido (ej: 1001, #1001)"
            }
          },
          "required": [
            "order_number"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://{{shopify_store}}.myshopify.com/admin/api/2024-10/orders.json?name={{order_number}}&status=any"
        }
      },
      {
        "key": "get_product",
        "description": "Obtiene información detallada de un producto por su ID.",
        "input_schema": {
          "type": "object",
          "properties": {
            "product_id": {
              "type": "string",
              "description": "ID del producto en Shopify"
            }
          },
          "required": [
            "product_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://{{shopify_store}}.myshopify.com/admin/api/2024-10/products/{{product_id}}.json"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "shopify_store",
      "type": "string",
      "label": "Nombre de la tienda"
    },
    {
      "key": "shopify_access_token",
      "type": "secret",
      "label": "Access Token"
    }
  ]
}
