{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "stripe",
    "name": "Stripe",
    "version": "1.0.0",
    "description": "Consulta pagos y genera links de cobro con Stripe.",
    "category": "payments",
    "icon": {
      "type": "brand",
      "slug": "stripe",
      "color": "#635BFF"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "*.stripe.com",
      "reason": "Llamadas a la API de Stripe"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "get_payment",
        "description": "Busca el estado de un pago/cargo en Stripe por su ID.",
        "input_schema": {
          "type": "object",
          "properties": {
            "charge_id": {
              "type": "string",
              "description": "ID del cargo (ch_...)"
            }
          },
          "required": [
            "charge_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.stripe.com/v1/charges/{{charge_id}}"
        }
      },
      {
        "key": "create_payment_link",
        "description": "Genera un link de pago para cobrar un monto específico.",
        "input_schema": {
          "type": "object",
          "properties": {
            "product_name": {
              "type": "string",
              "description": "Nombre del producto o concepto de pago"
            },
            "amount_cents": {
              "type": "number",
              "description": "Monto en centavos (ej: 50000 = $500.00 MXN)"
            }
          },
          "required": [
            "product_name",
            "amount_cents"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.stripe.com/v1/payment_links"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "stripe_secret_key",
      "type": "secret",
      "label": "Secret Key"
    }
  ]
}
