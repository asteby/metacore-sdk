{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "tavily_search",
    "name": "Búsqueda Web (Tavily)",
    "version": "1.0.0",
    "description": "Busca en Internet y obtiene resultados actualizados con IA. Ideal para responder preguntas que requieren información reciente o fuentes externas.",
    "category": "research",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=tavily.com&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.tavily.com",
      "reason": "Llamar a la API de búsqueda de Tavily"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "web_search",
        "description": "Realiza una búsqueda web y devuelve los resultados más relevantes con una respuesta directa.",
        "input_schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Consulta de búsqueda en lenguaje natural"
            }
          },
          "required": [
            "query"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.tavily.com/search"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "tavily_api_key",
      "type": "secret",
      "label": "Tavily API Key"
    }
  ]
}
