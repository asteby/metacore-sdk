{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "telegram",
    "name": "Telegram",
    "version": "1.0.0",
    "description": "Envía mensajes a grupos o chats de Telegram vía Bot API.",
    "category": "communication",
    "icon": {
      "type": "brand",
      "slug": "telegram",
      "color": "#26A5E4"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "api.telegram.org",
      "reason": "Bot API de Telegram"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "send_message",
        "description": "Envía un mensaje de texto a un chat de Telegram.",
        "input_schema": {
          "type": "object",
          "properties": {
            "telegram_bot_token": {
              "type": "string",
              "description": "Bot token de Telegram (provisto por settings)"
            },
            "message": {
              "type": "string",
              "description": "Texto del mensaje a enviar"
            }
          },
          "required": [
            "telegram_bot_token",
            "message"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://api.telegram.org/bot{{telegram_bot_token}}/sendMessage"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "telegram_bot_token",
      "type": "secret",
      "label": "Bot Token"
    },
    {
      "key": "telegram_chat_id",
      "type": "string",
      "label": "Chat ID"
    }
  ]
}
