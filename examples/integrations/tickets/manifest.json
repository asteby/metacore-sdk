{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "tickets",
    "name": "Tickets",
    "version": "1.0.0",
    "description": "Registra y gestiona tickets de soporte directamente en Link, con modals para resolver y reasignar, y tools LLM para crear/actualizar.",
    "category": "productivity",
    "icon": {
      "type": "lucide",
      "slug": "Ticket",
      "color": "#F59E0B"
    },
    "author": "Asteby",
    "website": "https://asteby.com",
    "license": "MIT",
    "features": [
      "Gestión de tickets de soporte",
      "Modals para resolver y reasignar",
      "Herramientas LLM para agentes conversacionales"
    ]
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "schema",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "event:emit",
      "target": "tickets.*",
      "reason": "Notificar eventos de tickets"
    }
  ],
  "models": [
    {
      "key": "Tickets",
      "table": "tickets",
      "label": "Tickets",
      "columns": [
        {
          "name": "id",
          "type": "uuid",
          "primary_key": true,
          "default": "gen_random_uuid()"
        },
        {
          "name": "organization_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "title",
          "type": "text",
          "not_null": true
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "status",
          "type": "text",
          "not_null": true,
          "default": "open"
        },
        {
          "name": "priority",
          "type": "text",
          "default": "medium"
        },
        {
          "name": "category",
          "type": "text"
        },
        {
          "name": "assignee_id",
          "type": "uuid"
        },
        {
          "name": "contact_id",
          "type": "uuid"
        },
        {
          "name": "resolution_notes",
          "type": "text"
        },
        {
          "name": "resolved_at",
          "type": "timestamptz"
        },
        {
          "name": "tags",
          "type": "jsonb"
        }
      ]
    }
  ],
  "frontend": {
    "entry": "/api/metacore/addons/tickets/frontend/remoteEntry.js",
    "format": "federation",
    "expose": "./plugin",
    "container": "metacore_tickets"
  },
  "contributions": {
    "navigation": [
      {
        "title": "addons.tickets.sidebar.tickets",
        "icon": "Ticket",
        "target": "sidebar.operations",
        "items": [
          {
            "title": "addons.tickets.sidebar.tickets",
            "model": "Tickets",
            "icon": "Ticket"
          }
        ]
      }
    ],
    "actions": [
      {
        "key": "resolve",
        "label": "addons.tickets.actions.resolve",
        "icon": "CheckCircle",
        "handler": {
          "type": "wasm",
          "function": "Resolve"
        },
        "target_model": "Tickets",
        "modal": "tickets.resolve",
        "fields": [
          {
            "key": "resolution_notes",
            "type": "text",
            "label": "Notas de resolución",
            "required": true
          }
        ]
      },
      {
        "key": "reassign",
        "label": "addons.tickets.actions.reassign",
        "icon": "UserCheck",
        "handler": {
          "type": "wasm",
          "function": "Reassign"
        },
        "target_model": "Tickets",
        "modal": "tickets.reassign",
        "fields": [
          {
            "key": "assignee_id",
            "type": "text",
            "label": "Nuevo responsable (UUID)",
            "required": true
          }
        ]
      }
    ],
    "tools": [
      {
        "key": "create_ticket",
        "description": "Registra un ticket de soporte a partir de la conversación.",
        "input_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Título corto del ticket"
            },
            "description": {
              "type": "string"
            },
            "priority": {
              "type": "string"
            },
            "category": {
              "type": "string"
            }
          },
          "required": [
            "title",
            "description"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/create_ticket"
        }
      },
      {
        "key": "update_ticket",
        "description": "Actualiza el estado, prioridad o asignación de un ticket existente.",
        "input_schema": {
          "type": "object",
          "properties": {
            "ticket_id": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "priority": {
              "type": "string"
            },
            "assignee_id": {
              "type": "string"
            },
            "comment": {
              "type": "string"
            }
          },
          "required": [
            "ticket_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "/webhooks/update_ticket"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "default_priority",
      "type": "select",
      "label": "Prioridad por defecto",
      "default": "medium",
      "options": [
        {
          "value": "low",
          "label": "Baja"
        },
        {
          "value": "medium",
          "label": "Media"
        },
        {
          "value": "high",
          "label": "Alta"
        },
        {
          "value": "urgent",
          "label": "Urgente"
        }
      ]
    }
  ]
}
