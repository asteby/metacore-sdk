{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "weather",
    "name": "Clima Actual",
    "version": "1.0.0",
    "description": "Consulta el clima actual de cualquier ciudad del mundo vía wttr.in. Sin API key requerida.",
    "category": "utilities",
    "icon": {
      "type": "url",
      "slug": "https://www.google.com/s2/favicons?domain=wttr.in&sz=128"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "wttr.in",
      "reason": "Consulta de clima sin API key"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "current_weather",
        "description": "Obtiene la temperatura y condición climática actual de una ciudad.",
        "input_schema": {
          "type": "object",
          "properties": {
            "city": {
              "type": "string",
              "description": "Nombre de la ciudad, puede incluir país"
            }
          },
          "required": [
            "city"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://wttr.in/{{city}}?format=3"
        }
      }
    ]
  }
}
