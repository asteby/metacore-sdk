{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "whatsapp_outbound",
    "name": "WhatsApp — Envío Externo",
    "version": "1.0.0",
    "description": "El agente envía mensajes a otros números y gestiona contactos usando el dispositivo de la conversación activa.",
    "category": "communication",
    "icon": {
      "type": "brand",
      "slug": "whatsapp",
      "color": "#25D366"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "http:fetch",
      "target": "graph.facebook.com",
      "reason": "Meta WhatsApp Cloud API (Graph)"
    }
  ],
  "contributions": {
    "tools": [
      {
        "key": "send_whatsapp",
        "description": "Envía un mensaje de WhatsApp a cualquier número usando el dispositivo de la conversación activa.",
        "input_schema": {
          "type": "object",
          "properties": {
            "phone": {
              "type": "string",
              "description": "Número destino con código de país"
            },
            "message": {
              "type": "string",
              "description": "Texto del mensaje a enviar"
            }
          },
          "required": [
            "phone",
            "message"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "https://graph.facebook.com/v20.0/me/messages"
        }
      },
      {
        "key": "list_contacts",
        "description": "Consulta contactos existentes en la organización para obtener nombres, teléfonos y emails.",
        "input_schema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Buscar por nombre, teléfono o email"
            },
            "limit": {
              "type": "number",
              "description": "Máximo de resultados (default 20, max 50)"
            }
          }
        },
        "handler": {
          "type": "webhook",
          "url": "https://graph.facebook.com/v20.0/me/contacts"
        }
      }
    ]
  }
}
