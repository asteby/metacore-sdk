{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "wordpress",
    "name": "WordPress",
    "version": "1.0.0",
    "description": "Publica y gestiona contenido en tu sitio WordPress desde conversaciones.",
    "category": "productivity",
    "icon": {
      "type": "brand",
      "slug": "wordpress",
      "color": "#21759B"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "contributions": {
    "tools": [
      {
        "key": "create_post",
        "description": "Publica un nuevo artículo en WordPress.",
        "input_schema": {
          "type": "object",
          "properties": {
            "wp_site_url": {
              "type": "string",
              "description": "URL base del sitio WordPress (default = settings.wp_site_url)"
            },
            "title": {
              "type": "string",
              "description": "Título del artículo"
            },
            "content": {
              "type": "string",
              "description": "Contenido del artículo en HTML"
            },
            "status": {
              "type": "string",
              "description": "Estado: publish (publicar) o draft (borrador)"
            }
          },
          "required": [
            "wp_site_url",
            "title",
            "content"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "{{wp_site_url}}/wp-json/wp/v2/posts"
        }
      },
      {
        "key": "list_posts",
        "description": "Busca artículos publicados en WordPress.",
        "input_schema": {
          "type": "object",
          "properties": {
            "wp_site_url": {
              "type": "string",
              "description": "URL base del sitio WordPress"
            },
            "query": {
              "type": "string",
              "description": "Término de búsqueda"
            }
          },
          "required": [
            "wp_site_url",
            "query"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "{{wp_site_url}}/wp-json/wp/v2/posts?search={{query}}&per_page=5"
        }
      }
    ]
  },
  "settings": [
    {
      "key": "wp_site_url",
      "type": "string",
      "label": "URL del sitio (https://mi-sitio.com)"
    },
    {
      "key": "wp_basic_auth",
      "type": "secret",
      "label": "Auth Token (Base64)"
    }
  ]
}
