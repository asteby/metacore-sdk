{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "tickets_native",
    "name": "Tickets (nativo)",
    "version": "1.0.0",
    "description": "Tickets de soporte — respaldado por el pipeline nativo de link vía webhook firmado.",
    "category": "productivity",
    "icon": {
      "type": "lucide",
      "slug": "Ticket"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "contributions": {
    "tools": [
      {
        "key": "create-ticket",
        "description": "Registra un ticket de soporte a partir de la conversación.",
        "input_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Título del ticket"
            },
            "description": {
              "type": "string",
              "description": "Descripción detallada"
            },
            "priority": {
              "type": "string",
              "description": "Prioridad: low, medium, high, urgent"
            },
            "category": {
              "type": "string",
              "description": "Categoría: bug, feature, question, complaint, support, other"
            },
            "tags": {
              "type": "string",
              "description": "Etiquetas separadas por coma"
            }
          },
          "required": [
            "title",
            "description"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "http://link-backend:8080/api/_mc/native/tickets_native/create-ticket"
        }
      },
      {
        "key": "list-tickets",
        "description": "Consulta tickets existentes con filtros de estado, prioridad o búsqueda.",
        "input_schema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Filtrar por estado: open, in_progress, resolved, closed"
            },
            "priority": {
              "type": "string",
              "description": "Filtrar por prioridad: low, medium, high, urgent"
            },
            "scope": {
              "type": "string",
              "description": "Alcance: 'conversation' para solo esta conversación, vacío para todos los del contacto"
            },
            "search": {
              "type": "string",
              "description": "Buscar por texto en título o descripción"
            },
            "limit": {
              "type": "number",
              "description": "Máximo de resultados (default 10, max 50)"
            }
          }
        },
        "handler": {
          "type": "webhook",
          "url": "http://link-backend:8080/api/_mc/native/tickets_native/list-tickets"
        }
      },
      {
        "key": "update-ticket",
        "description": "Actualiza el estado o prioridad de un ticket existente.",
        "input_schema": {
          "type": "object",
          "properties": {
            "ticket_id": {
              "type": "string",
              "description": "ID del ticket a actualizar"
            },
            "status": {
              "type": "string",
              "description": "Nuevo estado: open, in_progress, resolved, closed"
            },
            "priority": {
              "type": "string",
              "description": "Nueva prioridad: low, medium, high, urgent"
            },
            "comment": {
              "type": "string",
              "description": "Comentario o nota adicional"
            }
          },
          "required": [
            "ticket_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "http://link-backend:8080/api/_mc/native/tickets_native/update-ticket"
        }
      },
      {
        "key": "close-ticket",
        "description": "Cierra un ticket de soporte existente, marcándolo como resuelto.",
        "input_schema": {
          "type": "object",
          "properties": {
            "ticket_id": {
              "type": "string",
              "description": "ID o número del ticket a cerrar (ej: SUP-100)"
            },
            "resolution": {
              "type": "string",
              "description": "Descripción de la resolución o motivo de cierre"
            }
          },
          "required": [
            "ticket_id"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "http://link-backend:8080/api/_mc/native/tickets_native/close-ticket"
        }
      }
    ]
  }
}
