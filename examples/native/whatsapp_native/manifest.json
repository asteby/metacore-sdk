{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "whatsapp_native",
    "name": "WhatsApp (nativo)",
    "version": "1.0.0",
    "description": "Mensajería WhatsApp saliente respaldada por el pipeline nativo de link.",
    "category": "communication",
    "icon": {
      "type": "brand",
      "slug": "whatsapp",
      "color": "#25D366"
    },
    "author": "asteby",
    "license": "MIT"
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "shared",
    "rls_column": "organization_id"
  },
  "contributions": {
    "tools": [
      {
        "key": "send-whatsapp",
        "description": "Envía un mensaje de WhatsApp a cualquier número usando el dispositivo de la conversación activa.",
        "input_schema": {
          "type": "object",
          "properties": {
            "phone": {
              "type": "string",
              "description": "Número destino con código de país"
            },
            "message": {
              "type": "string",
              "description": "Texto del mensaje a enviar"
            }
          },
          "required": [
            "phone",
            "message"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "http://link-backend:8080/api/_mc/native/whatsapp_native/send-whatsapp"
        }
      },
      {
        "key": "list-contacts",
        "description": "Consulta contactos existentes en la organización para obtener nombres, teléfonos y emails.",
        "input_schema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Buscar por nombre, teléfono o email"
            },
            "limit": {
              "type": "number",
              "description": "Máximo de resultados (default 20, max 50)"
            }
          }
        },
        "handler": {
          "type": "webhook",
          "url": "http://link-backend:8080/api/_mc/native/whatsapp_native/list-contacts"
        }
      },
      {
        "key": "list-contacts",
        "description": "Lista contactos del tenant con filtros por nombre o teléfono. Úsalo cuando el usuario pida 'a quién le mandé', 'mis contactos', o busque identificar a un cliente.",
        "input_schema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Texto a buscar en nombre o teléfono"
            },
            "limit": {
              "type": "number",
              "description": "Máximo de resultados (default 20, max 100)"
            }
          }
        },
        "handler": {
          "type": "webhook",
          "url": "http://link-backend:8080/api/_mc/native/whatsapp_native/list-contacts"
        }
      }
    ]
  }
}
