{
  "apiVersion": "asteby.com/v3",
  "kind": "Addon",
  "metadata": {
    "key": "order_generation",
    "name": "Order Generation",
    "version": "1.0.0",
    "description": "Genera pedidos desde conversaciones de IA. Aislado por org vía schema-per-tenant.",
    "category": "commerce",
    "icon": {
      "type": "lucide",
      "slug": "ShoppingCart"
    },
    "author": "asteby",
    "license": "MIT",
    "features": [
      "Crear pedidos desde chat con extracción automática de parámetros",
      "Listado y cancelación por número de orden",
      "Aislamiento físico por org — schema propio por instalación"
    ]
  },
  "compatibility": {
    "requires": [
      {
        "key": "kernel",
        "version": ">=3.0.0 <4.0.0"
      }
    ]
  },
  "tenancy": {
    "isolation": "schema",
    "rls_column": "organization_id"
  },
  "capabilities": [
    {
      "kind": "event:emit",
      "target": "order.*",
      "reason": "Notificar creación y cambios de estado de pedidos"
    },
    {
      "kind": "http:fetch",
      "target": "api.stripe.com",
      "reason": "Procesar cobros opcionales"
    }
  ],
  "models": [
    {
      "key": "Orders",
      "table": "orders",
      "label": "Pedidos",
      "columns": [
        {
          "name": "id",
          "type": "uuid",
          "primary_key": true,
          "default": "gen_random_uuid()"
        },
        {
          "name": "organization_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "order_number",
          "type": "text",
          "not_null": true
        },
        {
          "name": "customer_phone",
          "type": "text"
        },
        {
          "name": "customer_name",
          "type": "text"
        },
        {
          "name": "total_amount",
          "type": "numeric",
          "not_null": true,
          "default": "0"
        },
        {
          "name": "status",
          "type": "text",
          "not_null": true,
          "default": "pending"
        },
        {
          "name": "channel",
          "type": "text",
          "default": "whatsapp"
        },
        {
          "name": "metadata",
          "type": "jsonb"
        }
      ]
    },
    {
      "key": "OrderItems",
      "table": "order_items",
      "label": "Items del pedido",
      "columns": [
        {
          "name": "id",
          "type": "uuid",
          "primary_key": true,
          "default": "gen_random_uuid()"
        },
        {
          "name": "organization_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "order_id",
          "type": "uuid",
          "not_null": true
        },
        {
          "name": "product_sku",
          "type": "text",
          "not_null": true
        },
        {
          "name": "product_name",
          "type": "text",
          "not_null": true
        },
        {
          "name": "quantity",
          "type": "numeric",
          "not_null": true,
          "default": "1"
        },
        {
          "name": "unit_price",
          "type": "numeric",
          "not_null": true,
          "default": "0"
        }
      ]
    }
  ],
  "contributions": {
    "navigation": [
      {
        "title": "sidebar.orders.group",
        "icon": "ShoppingCart",
        "target": "sidebar.operations",
        "items": [
          {
            "title": "sidebar.orders.list",
            "model": "Orders",
            "icon": "ListOrdered"
          }
        ]
      }
    ],
    "tools": [
      {
        "key": "create_order",
        "description": "Crea un pedido nuevo con uno o más productos. Usa esta herramienta cuando el cliente exprese intención de comprar u ordenar productos.",
        "input_schema": {
          "type": "object",
          "properties": {
            "customer_phone": {
              "type": "string",
              "description": "Teléfono del cliente"
            },
            "customer_name": {
              "type": "string",
              "description": "Nombre del cliente"
            },
            "product_sku": {
              "type": "string",
              "description": "SKU del producto solicitado"
            },
            "quantity": {
              "type": "number",
              "description": "Cantidad solicitada"
            }
          },
          "required": [
            "customer_phone",
            "product_sku",
            "quantity"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "http://localhost:7200/webhooks/create_order"
        }
      },
      {
        "key": "list_orders",
        "description": "Muestra los pedidos recientes del cliente identificado por su teléfono.",
        "input_schema": {
          "type": "object",
          "properties": {
            "customer_phone": {
              "type": "string",
              "description": "Teléfono del cliente"
            }
          },
          "required": [
            "customer_phone"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "http://localhost:7200/webhooks/list_orders"
        }
      },
      {
        "key": "cancel_order",
        "description": "Cancela un pedido por su número si aún no ha sido enviado.",
        "input_schema": {
          "type": "object",
          "properties": {
            "order_number": {
              "type": "string",
              "description": "Número del pedido a cancelar"
            }
          },
          "required": [
            "order_number"
          ]
        },
        "handler": {
          "type": "webhook",
          "url": "http://localhost:7200/webhooks/cancel_order"
        }
      }
    ]
  },
  "extension_points": {
    "events": [
      {
        "name": "order.created"
      },
      {
        "name": "order.cancelled"
      },
      {
        "name": "order.fulfilled"
      }
    ]
  },
  "settings": [
    {
      "key": "order_prefix",
      "type": "string",
      "label": "Prefijo de pedido",
      "default": "ORD"
    },
    {
      "key": "starting_number",
      "type": "number",
      "label": "Número inicial",
      "default": 1000
    }
  ]
}
