{
  "name": "@asteby/metacore-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Metacore SDK monorepo — reusable packages for the metacore ecosystem",
  "repository": {
    "type": "git",
    "url": "https://github.com/asteby/metacore-sdk"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "codegen": "go run github.com/gzuidhof/tygo@v0.2.17 generate"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.27.9",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^6.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3"
    }
  }
}
