{
  "name": "@asteby/metacore-app-providers",
  "version": "0.6.0",
  "description": "Providers genéricos reutilizables para apps metacore (direction, font, layout, search, platform-config)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asteby/metacore-sdk",
    "directory": "packages/app-providers"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@radix-ui/react-direction": "^1.1.0",
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "@asteby/metacore-pwa": ">=0.3.1",
    "@asteby/metacore-runtime-react": ">=7.1.5",
    "@asteby/metacore-ui": ">=0.7"
  },
  "peerDependenciesMeta": {
    "@asteby/metacore-pwa": {
      "optional": true
    },
    "@asteby/metacore-runtime-react": {
      "optional": true
    },
    "@asteby/metacore-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@asteby/metacore-pwa": "workspace:*",
    "@asteby/metacore-runtime-react": "workspace:*",
    "@asteby/metacore-ui": "workspace:*",
    "@radix-ui/react-direction": "^1.1.1",
    "@tanstack/react-query": "^5.59.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
