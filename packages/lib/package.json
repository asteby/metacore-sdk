{
  "name": "@asteby/metacore-lib",
  "version": "0.2.0",
  "description": "Metacore utilities — date/currency/number formatting, error handling, cookies",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asteby/metacore-sdk",
    "directory": "packages/lib"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "import": "./dist/date.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "import": "./dist/format.js"
    },
    "./currency": {
      "types": "./dist/currency.d.ts",
      "import": "./dist/currency.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "date-fns": ">=3",
    "sonner": ">=1.7"
  },
  "peerDependenciesMeta": {
    "sonner": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "date-fns": "^4.1.0",
    "sonner": "^1.7.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
