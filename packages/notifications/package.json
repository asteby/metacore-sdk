{
  "name": "@asteby/metacore-notifications",
  "version": "6.0.0",
  "description": "Metacore notifications — dropdown, app badge, WebSocket-driven real-time updates",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asteby/metacore-sdk",
    "directory": "packages/notifications"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dropdown": {
      "types": "./dist/dropdown.d.ts",
      "import": "./dist/dropdown.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@asteby/metacore-ui": "workspace:^",
    "@asteby/metacore-websocket": "workspace:^",
    "@tanstack/react-query": ">=5",
    "date-fns": ">=3",
    "lucide-react": ">=0.460",
    "sonner": ">=1.7"
  },
  "devDependencies": {
    "@asteby/metacore-ui": "workspace:*",
    "@asteby/metacore-websocket": "workspace:*",
    "@tanstack/react-query": "^5.95.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.0",
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
