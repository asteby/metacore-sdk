{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@asteby/metacore-sdk": ["../sdk/src/index.ts"],
      "@asteby/metacore-sdk/*": ["../sdk/src/*"]
    }
  },
  "include": ["src/**/*"]
}
