{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    },
    "ignoreDeprecations": "6.0",
    "types": ["vite/client"],
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts",
    "src/lib/**/*",
    "src/components/ui/**/*"
  ]
}
