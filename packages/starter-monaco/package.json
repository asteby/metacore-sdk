{
  "name": "@asteby/metacore-starter-monaco",
  "version": "0.2.0",
  "description": "Opt-in Monaco editor wrapper extracted from @asteby/metacore-starter-core. Apps without an embedded code editor avoid the ~2MB Monaco bundle entirely.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asteby/metacore-sdk",
    "directory": "packages/starter-monaco"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": ">=0.460",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
