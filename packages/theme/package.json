{
  "name": "@asteby/metacore-theme",
  "version": "0.1.0",
  "description": "Metacore design tokens + Tailwind 4 preset (oklch, shadows, fonts, dark mode)",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/asteby/metacore-sdk", "directory": "packages/theme" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "styles", "README.md"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./tokens.css": "./styles/tokens.css",
    "./index.css": "./styles/index.css",
    "./fonts": { "types": "./dist/fonts.d.ts", "import": "./dist/fonts.js" },
    "./preset": { "types": "./dist/preset.d.ts", "import": "./dist/preset.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "publishConfig": { "access": "public" }
}
