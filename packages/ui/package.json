{
  "name": "@asteby/metacore-ui",
  "version": "0.6.0",
  "description": "Metacore UI kit — data-table, layout shell, command-menu, hooks y primitives shadcn reutilizables",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/asteby/metacore-sdk",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./data-table": {
      "types": "./dist/data-table/index.d.ts",
      "import": "./dist/data-table/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js"
    },
    "./dialogs": {
      "types": "./dist/dialogs/index.d.ts",
      "import": "./dist/dialogs/index.js"
    },
    "./command-menu": {
      "types": "./dist/command-menu/index.d.ts",
      "import": "./dist/command-menu/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./icons/brand": {
      "types": "./dist/icons/brand/index.d.ts",
      "import": "./dist/icons/brand/index.js"
    },
    "./icons/custom": {
      "types": "./dist/icons/custom/index.d.ts",
      "import": "./dist/icons/custom/index.js"
    },
    "./error-pages": {
      "types": "./dist/error-pages/index.d.ts",
      "import": "./dist/error-pages/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7",
    "react-i18next": ">=13",
    "@tanstack/react-table": ">=8",
    "@tanstack/react-query": ">=5",
    "@tanstack/react-router": ">=1.100",
    "tailwindcss": ">=4"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.460.0",
    "react-day-picker": "^9.4.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-table": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.1.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
